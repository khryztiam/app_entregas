# ========== PostgreSQL + Prisma ==========
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/app_enysa"

# ========== JWT Authentication (local) ==========
# AUTH_SECRET DEBE tener al menos 32 caracteres
# Genera uno: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="cambiar-esto-local-con-minimo-32-caracteres-abcdefghij1234567890"

# ========== Branding (genérico) ==========
NEXT_PUBLIC_APP_NAME=Workspace Hub
NEXT_PUBLIC_APP_SHORT_NAME=Workspace
NEXT_PUBLIC_APP_DESCRIPTION=Gestion centralizada de recursos, movimientos y personas

# ========== Environment ==========
NODE_ENV=development
